    "next_review": "2026-08-08"
  },
  "intended_use": {
    "primary": "Calculate settlement terms; check authority matrix; STP express auto-payment for PD \u2264 $15k with no injury and fraud cleared; FCRA-compliant adverse action notice when claim reduced or denied.",
    "in_scope": [
      "US personal-lines auto first-party claims",
      "All 50 US states"
    ],
    "out_of_scope": [
      "Commercial auto",
      "Workers' comp",
      "Pricing/underwriting"
    ]
  },
  "model_type": "hybrid_rules_plus_ml",
  "training_approach": "Rules + heuristics calibrated against POC closed-claim outcomes. ML uplift planned for v4. No demographic features used.",
  "inputs": {
    "data_sources": [
      {
        "source": "Damage Estimation (A5)",
        "sensitivity": "financial",
        "fields": [
          "damageEstimateUSD",
          "totalLossFlag"
        ]
      },
      {
        "source": "BI Evaluation (A6)",
        "sensitivity": "PHI + financial",
        "fields": [
          "settlementP50"
        ]
      },
      {
        "source": "Fraud Detection (A4)",
        "sensitivity": "PII",
        "fields": [
          "fraudBand",
          "paymentHoldFlag"
        ]
      },
      {
        "source": "Coverage Agent (A2)",
        "sensitivity": "financial",
        "fields": [
          "coverageDecision",
          "deductibleAmount",
          "limits"
        ]
      }
    ],
    "prohibited_inputs": [
      "Race/ethnicity",
      "Religion",
      "National origin",
      "Sexual orientation",
      "Genetic information",
      "Credit score in claims handling"
    ]
  },
  "outputs": {
    "fields": [
      "settlementAmount",
      "paymentMethod",
      "eftStatus",
      "claimStatus",
      "adverseActionNotice",
      "supervisorApprovalRequired"
    ],
    "decision_record_emitted": true,
    "hitl_gate": "confidence < 0.70"
  },
  "performance": {
    "metrics": [
      {
        "name": "stp_payment_accuracy",
        "current": 0.92,
        "target": 0.97
      },
      {
        "name": "adverse_action_notice_compliance",
        "current": 1.0,
        "target": 1.0
      }
    ],
    "calibration": {
      "expected_calibration_error": 0.04,
      "target_ece": 0.05
    }
  },
  "fairness": {
    "monitored": false,
    "monitor": "governance/bias_monitor.py",
    "protected_attributes": [],
    "metrics": [
      {
        "demographic_parity_ratio": 0.8
      },
      {
        "equalized_odds_difference": 0.1
      },
      {
        "calibration_by_group": 0.02
      }
